---
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
  /** 'article' for blog posts, 'website' for other pages */
  ogType?: "article" | "website";
  /** Show the CSS scroll-driven reading progress bar (blog posts only) */
  showProgress?: boolean;
}

const {
  title,
  description = "Personal essays and technical writing.",
  ogImage,
  pubDate,
  ogType = "website",
  showProgress = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "Global Minima";

// Active nav detection
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname;
const isAbout  = pathname === `${base}/about` || pathname === `${base}/about/`;
const isEssays = pathname.startsWith(`${base}/essays`) || pathname.startsWith(`${base}/blog`);
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : undefined;
---

<!doctype html>
<html lang="en" id="top">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title === siteName ? title : `${title} — ${siteName}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    {
      pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteName} RSS Feed`}
      href={new URL("rss.xml", Astro.site)}
    />

    <!-- Favicon — must include base path to match Astro's public/ asset routing -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

    <!-- Set data-theme before first paint to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem("theme");
        if (t === "dark" || t === "light")
          document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>

  <body>
    {showProgress && <div class="reading-progress" aria-hidden="true" />}
    <header class="site-header">
      <nav class="site-nav">
        <a href={import.meta.env.BASE_URL || "/"} class="site-title"
          >{siteName}</a
        >
        <a href={`${base}/about`} aria-current={isAbout ? 'page' : undefined}>About</a>
        <a href={`${base}/essays`} aria-current={isEssays ? 'page' : undefined}>Essays</a>
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Switch theme"
        >
          <!--
            Atreides eagle: shown in dark mode (Harkonnen) — click to return to House Atreides (light).
            Harkonnen Black Sun of Giedi Prime: shown in light mode — click to enter Harkonnen darkness.
            CSS crossfades between them based on data-theme / prefers-color-scheme.
          -->
          <svg
            class="icon-atreides"
            viewBox="0 0 100 100"
            fill="currentColor"
            aria-hidden="true"
            width="38"
            height="38"
          >
            <!--
              House Atreides eagle: wings sweep sharply upward to the top corners (heraldic raised-wing pose),
              two-part kinked wing profile, narrow body, forked Y-tail.
            -->
            <path
              d="M47.49,89.31 L44.65,86.38 L44.65,74.73 L44.65,63.09 L23.92,42.37 L3.20,21.64 L3.07,15.26 C3.00,11.75 3.05,8.59 3.19,8.24 C3.37,7.77 9.61,13.78 27.01,31.18 L50.59,54.76 L73.50,31.85 C86.10,19.26 96.55,8.95 96.73,8.95 C96.91,8.95 97.00,12.07 96.93,15.89 L96.80,22.83 L76.69,42.96 L56.57,63.09 L56.46,74.88 L56.35,86.67 L53.58,89.45 C52.06,90.99 50.71,92.24 50.57,92.24 C50.44,92.24 49.05,90.92 47.49,89.31 Z M37.30,79.15 L32.95,74.78 L32.82,70.32 L32.69,65.86 L21.12,54.26 L9.54,42.66 L9.41,37.86 C9.34,35.21 9.43,32.90 9.62,32.71 C9.82,32.51 16.97,39.37 26.12,48.53 L42.27,64.70 L42.27,74.11 C42.27,79.28 42.13,83.51 41.96,83.51 C41.79,83.51 39.70,81.55 37.30,79.15 Z M58.92,74.09 L58.92,64.67 L74.59,49.01 C83.21,40.39 90.27,33.52 90.28,33.74 C90.29,33.96 90.34,36.32 90.38,38.99 L90.45,43.84 L79.25,55.07 L68.05,66.29 L68.05,70.66 L68.05,75.03 L63.74,79.27 C61.38,81.61 59.32,83.51 59.18,83.51 C59.04,83.51 58.92,79.27 58.92,74.09 Z M46.52,47.91 C44.40,45.78 42.66,43.86 42.66,43.64 C42.66,43.42 44.54,41.37 46.84,39.09 L51.01,34.93 L54.98,34.93 C59.30,34.93 59.70,35.12 59.71,37.21 C59.72,38.51 59.46,38.56 58.33,37.51 L57.49,36.72 L56.14,38.11 L54.80,39.50 L56.75,41.48 L58.71,43.47 L54.55,47.63 L50.39,51.79 L46.52,47.91Z"
            ></path>
          </svg>
          <svg
            class="icon-harkonnen"
            viewBox="0 0 100 100"
            fill="currentColor"
            aria-hidden="true"
            width="38"
            height="38"
          >
            <!--
              Harkonnen Black Sun of Giedi Prime: dominant top spike (≈half the symbol height),
              two curved sickle-like hooks extending from the center outward and downward,
              short bottom fork, circle punched from center via evenodd.
            -->
            <path
              d="M49.58,96.67 C49.37,96.34 49.07,95.45 47.52,90.54 C46.00,85.73 45.29,84.72 42.53,83.42 C41.63,82.99 40.30,82.24 39.57,81.76 C35.44,78.99 29.66,72.84 29.66,71.21 C29.66,70.81 29.72,70.73 30.10,70.66 C30.34,70.61 30.54,70.50 30.54,70.41 C30.54,70.02 28.84,68.83 26.94,67.88 C25.85,67.34 24.13,66.71 21.51,65.87 C19.23,65.15 18.20,64.69 18.20,64.41 C18.20,64.27 18.37,64.20 19.11,63.99 C19.30,63.94 23.84,63.88 29.20,63.84 L38.95,63.79 L37.76,65.11 C36.45,66.57 36.15,67.06 35.89,68.16 C35.51,69.77 36.22,71.37 38.25,73.48 C42.24,77.63 46.83,79.49 51.47,78.86 C54.05,78.50 57.07,77.01 59.60,74.83 C63.63,71.36 64.93,66.81 63.61,60.78 C62.71,56.69 60.58,53.36 57.71,51.57 C57.06,51.17 55.54,50.73 54.44,50.64 C53.25,50.55 52.83,50.34 52.54,49.75 C52.39,49.43 52.20,49.31 51.69,49.22 C51.32,49.15 50.88,49.07 50.69,49.03 C50.31,48.95 50.01,48.37 49.87,47.43 C49.72,46.41 49.63,40.90 49.57,28.48 C49.51,15.25 49.38,9.42 49.09,6.92 C48.92,5.43 48.95,3.33 49.14,3.14 C49.37,2.91 50.03,3.08 50.20,3.41 C50.28,3.55 50.38,4.22 50.43,4.91 C50.48,5.60 50.55,6.36 50.58,6.62 C50.62,6.87 50.69,7.50 50.74,8.01 C50.80,8.53 50.86,9.11 50.88,9.32 C50.95,9.95 51.10,11.28 51.17,11.81 C51.20,12.10 51.27,12.69 51.32,13.13 C51.43,14.19 51.53,15.00 51.61,15.63 C51.65,15.91 51.72,16.46 51.76,16.84 C51.80,17.23 51.87,17.85 51.91,18.24 C51.96,18.62 52.02,19.17 52.06,19.47 C52.10,19.76 52.16,20.25 52.20,20.57 C52.28,21.34 52.45,22.74 52.65,24.30 C52.69,24.58 52.75,25.14 52.80,25.55 C52.84,25.95 52.90,26.44 52.94,26.65 C52.97,26.85 53.03,27.38 53.08,27.82 C53.14,28.27 53.20,28.79 53.23,29.00 C53.27,29.20 53.33,29.73 53.38,30.17 C53.43,30.62 53.49,31.14 53.53,31.35 C53.56,31.55 53.62,32.04 53.67,32.45 C53.72,32.85 53.78,33.35 53.82,33.55 C53.85,33.75 53.92,34.25 53.96,34.65 C54.01,35.06 54.11,35.78 54.19,36.27 C54.26,36.75 54.36,37.41 54.41,37.74 C54.45,38.06 54.52,38.49 54.56,38.69 C54.60,38.89 54.67,39.26 54.70,39.50 C54.84,40.35 55.26,42.00 55.47,42.49 C55.82,43.34 56.94,44.37 59.16,45.88 C64.31,49.38 66.41,51.70 68.72,56.49 C70.20,59.58 70.42,59.75 74.86,61.18 C80.63,63.03 81.72,63.49 81.72,64.03 C81.72,64.50 80.55,65.01 76.92,66.15 C75.09,66.72 73.24,67.34 72.81,67.51 C71.01,68.24 70.22,69.07 68.72,71.76 C67.25,74.43 65.46,77.04 64.17,78.40 C62.18,80.50 60.83,81.40 56.83,83.27 C55.50,83.89 54.36,84.45 54.30,84.50 C54.24,84.56 53.40,87.11 52.45,90.18 C50.78,95.52 50.23,97.00 49.93,97.00 C49.85,97.00 49.69,96.85 49.58,96.67Z"
            ></path>
          </svg>
        </button>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>© {new Date().getFullYear()} {siteName}</span>
        <span>
          Built with <a href="https://astro.build">Astro</a>
        </span>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var btn = document.getElementById("theme-toggle");
        var html = document.documentElement;

        function current() {
          if (html.dataset.theme) return html.dataset.theme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        function sync() {
          var t = current();
          /* aria-label names the house you'll switch TO; icons handled by CSS */
          btn.setAttribute(
            "aria-label",
            t === "dark"
              ? "Switch to House Atreides (light mode)"
              : "Switch to House Harkonnen (dark mode)",
          );
        }

        sync();
        /* Keep in sync if system pref changes while page is open */
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", sync);

        btn.addEventListener("click", function () {
          var next = current() === "dark" ? "light" : "dark";
          html.dataset.theme = next;
          localStorage.setItem("theme", next);
          sync();
        });
      })();
    </script>
  </body>
</html>
