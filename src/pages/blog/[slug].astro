---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getSlug } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  );

  return posts.map((post, index) => ({
    params: { slug: getSlug(post.id) },
    props: {
      post,
      prev: index > 0
        ? { slug: getSlug(posts[index - 1].id), title: posts[index - 1].data.title }
        : null,
      next: index < posts.length - 1
        ? { slug: getSlug(posts[index + 1].id), title: posts[index + 1].data.title }
        : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
// Astro 6: use render() from astro:content instead of post.render()
const { Content } = await render(post);
---

<BlogPost post={post} prev={prev} next={next}>
  <Content />
</BlogPost>
