---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getSlug, readingTime } from '../utils/reading-time';

// Fetch all non-draft posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const base = import.meta.env.BASE_URL;

// Group: year (desc) → month index (desc) → posts (already sorted newest-first)
type PostEntry = (typeof posts)[number];
const grouped: Map<number, Map<number, PostEntry[]>> = new Map();

for (const post of posts) {
  const y = post.data.pubDate.getFullYear();
  const m = post.data.pubDate.getMonth(); // 0-indexed
  if (!grouped.has(y)) grouped.set(y, new Map());
  const yearMap = grouped.get(y)!;
  if (!yearMap.has(m)) yearMap.set(m, []);
  yearMap.get(m)!.push(post);
}

const sortedYears = [...grouped.keys()].sort((a, b) => b - a);

const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

function shortDateFull(d: Date): string {
  return d.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title="Essays" description="All essays, grouped by year and month.">
  <main class="page-container">
    {posts.length === 0 ? (
      <p style="color: var(--muted); font-family: system-ui, sans-serif; font-size: 0.9rem;">
        No posts yet. Check back soon.
      </p>
    ) : (
      <div class="essays-archive">
        {sortedYears.map((year) => {
          const yearMap = grouped.get(year)!;
          // Sort months descending (most recent month first)
          const sortedMonths = [...yearMap.keys()].sort((a, b) => b - a);
          const yearCount = [...yearMap.values()].reduce((s, arr) => s + arr.length, 0);
          return (
            <section class="year-section">
              <h2 class="year-heading">{year}<sup class="essays-count">{yearCount}</sup></h2>
              {sortedMonths.map((monthIdx) => {
                const monthPosts = yearMap.get(monthIdx)!;
                return (
                  <div class="month-section">
                    <h3 class="month-heading">{MONTH_NAMES[monthIdx]}<sup class="essays-count">{monthPosts.length}</sup></h3>
                    <ol class="essays-list">
                      {monthPosts.map((post) => (
                        <li class="essays-item">
                          <div class="essays-title-row">
                            <a
                              class="essays-title"
                              href={`${base}/blog/${getSlug(post.id)}`}
                            >
                              {post.data.title}
                            </a>
                            {post.data.tags.length > 0 && (
                              <div class="essays-tags">
                                {post.data.tags.map((tag) => (
                                  <a href={`${base}/tags/${tag}`} class="tag">
                                    {tag}
                                  </a>
                                ))}
                              </div>
                            )}
                            <div class="essays-meta">
                              <time datetime={post.data.pubDate.toISOString()}>
                                {shortDateFull(post.data.pubDate)}
                              </time>
                              {' · '}
                              {readingTime(post.body ?? '')} min read
                            </div>
                        </div>
                        </li>
                      ))}
                    </ol>
                  </div>
                );
              })}
            </section>
          );
        })}
      </div>
    )}
  </main>
</Layout>
