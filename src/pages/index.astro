---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { readingTime, getSlug } from '../utils/reading-time';

// Fetch all non-draft posts, newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function shortDateFull(d: Date): string {
  return d.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title="Global Minima" description="Personal essays and technical writing.">
  <main class="page-container">
    {posts.length === 0 ? (
      <p style="color: var(--muted); font-family: system-ui, sans-serif; font-size: 0.9rem;">
        No posts yet. Check back soon.
      </p>
    ) : (
      <ol class="essays-list">
        {posts.map((post) => (
          <li class="essays-item">
            <div class="essays-title-row">
              <a class="essays-title" href={`${base}/blog/${getSlug(post.id)}`}>
                {post.data.title}
              </a>
              {post.data.tags.length > 0 && (
                <div class="essays-tags">
                  {post.data.tags.map((tag) => (
                    <a href={`${base}/tags/${tag}`} class="tag">{tag}</a>
                  ))}
                </div>
              )}
              <div class="essays-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {shortDateFull(post.data.pubDate)}
                </time>
                {' · '}
                {readingTime(post.body ?? '')} min read
              </div>
            </div>
          </li>
        ))}
      </ol>
    )}
  </main>
</Layout>
